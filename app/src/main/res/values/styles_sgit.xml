<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
         Theme.Sgit used to also set a full set of 2012-era "Action Bar Style Generator"
         Holo action-bar/popup/tab/spinner/progress-bar/cab styles here. Every activity now
         uses the .NoActionBar variant of this theme (see styles.xml) and renders its own
         Compose TopAppBar instead of a system ActionBar, so those attributes were never
         read anymore, so they were removed along with their drawables/styles. ic_branch_l/
         ic_tag_l are still read directly via Profile.getStyledResource() by the rebase/merge
         branch pickers. The Files tab moved to Compose and no longer needs ic_file_fl/
         ic_folder_fl, so they were removed along with the now-unused ic_file_d/ic_folder_d/
         ic_folder_w drawables.
    -->
    <style name="Theme.Sgit" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="android:actionMenuTextColor">@android:color/black</item>
        <item name="android:textColor">@android:color/black</item>
        <item type="drawable" name="ic_branch_l">@drawable/ic_branch_d</item>
        <item type="drawable" name="ic_tag_l">@drawable/ic_tag_d</item>

        <!-- this strangely fixes the "flash" of the default light theme on app startup when the
          dark theme is selected, from: http://stackoverflow.com/a/29202453/85472 -->
        <item name="android:windowDisablePreview">true</item>
    </style>

</resources>
